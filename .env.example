# Template de variables de entorno — NO commitear valores reales
# Copiá este archivo a .env.local y completá los valores.
# Los mismos valores se pegan en Vercel (Settings → Environment Variables).

# ─────────────────────────────────────────────────────────────
# Supabase (fuente: Supabase Dashboard → Project Settings → API)
# Project: wioozisskjjgjjybsoqo
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://wioozisskjjgjjybsoqo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Sólo para regen local de types (no runtime):
SUPABASE_ACCESS_TOKEN=sbp_...

# ─────────────────────────────────────────────────────────────
# Gotenberg (PDF rendering)
# ─────────────────────────────────────────────────────────────
GOTENBERG_URL=https://demo-ia-gotenberg.ccralj.easypanel.host

# ─────────────────────────────────────────────────────────────
# Resend (emails transaccionales)
# fuente: https://resend.com/api-keys
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ─────────────────────────────────────────────────────────────
# Cron jobs (protege los endpoints /api/cron/*)
# Generar con: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────
CRON_SECRET=

# ─────────────────────────────────────────────────────────────
# Site URL (dominio prod — usado en los links dentro de emails)
# En Vercel dejalo como el dominio público real.
# En local podés usar http://localhost:3000
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://web.reportar.app

# ─────────────────────────────────────────────────────────────
# Entorno (production | test)
# En producción: NEXT_PUBLIC_ENV=production
# En servidor de pruebas: NEXT_PUBLIC_ENV=test  (muestra banner)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_ENV=production

# ─────────────────────────────────────────────────────────────
# Sentry (monitoreo de errores)
# fuente: sentry.io → Settings → Projects → Client Keys (DSN)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_DSN=https://...@sentry.io/...
SENTRY_ORG=
SENTRY_PROJECT=reporta-web
SENTRY_AUTH_TOKEN=

# ─────────────────────────────────────────────────────────────
# DB Push — URLs de conexión directa para scripts/db-push.ts
# Formato: postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
# Obtener password: Supabase Dashboard → Project Settings → Database
# ─────────────────────────────────────────────────────────────
TEST_DB_URL=postgresql://postgres:[PASSWORD]@db.wioozisskjjgjjybsoqo.supabase.co:5432/postgres
PROD_DB_URL=postgresql://postgres:[PASSWORD]@db.fqwhagryqkkhbgznxtwf.supabase.co:5432/postgres

# ─────────────────────────────────────────────────────────────
# Testing (opcional — sólo para Playwright E2E en CI)
# ─────────────────────────────────────────────────────────────
# TEST_BASE_URL=http://localhost:3000
# VERIFICATION_MODE=false
# TEST_TENANT_ID=
# TEST_USER_ID=
